# Charis G Platform — 환경변수 예제
# 실제 .env 는 프로젝트 루트에 두고 git 에 커밋하지 말 것

# ━━━━━━ 인증 / Hub ━━━━━━
JWT_SECRET=please-change-me-to-random-256bit
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
CTRL_AUTH_BYPASS=false
CTRL_ADMIN_USER=admin
CTRL_ADMIN_PASS=

# ━━━━━━ AI ━━━━━━
AI_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ━━━━━━ DS — CJ Dropshipping ━━━━━━
CJ_API_KEY=
CJ_EMAIL=
CJ_PASSWORD=

# ━━━━━━ DS — Webshare 프록시 (Amazon 크롤러용) ━━━━━━
PROXY_HOST=
PROXY_PORT=
PROXY_USER_BASE=
PROXY_PASSWORD=

# ━━━━━━ PA — 네이버 ━━━━━━
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# ━━━━━━ PA — 쿠팡 ━━━━━━
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# ━━━━━━ Google Sheets / GitHub ━━━━━━
SHEET_ID=
GOOGLE_SA_KEY_PATH=
GITHUB_TOKEN=
GITHUB_REPO=

# ━━━━━━ Hub ↔ DS/PA inter-service URLs ━━━━━━
DS_API_BASE=http://127.0.0.1:8001
PA_API_BASE=http://127.0.0.1:8002

# ━━━━━━ DB 경로 (선택) ━━━━━━
HUB_DB_PATH=./backend/hub/hub.db
DS_DB_PATH=./backend/dropshipping/dropshipping.db
PA_DB_PATH=./backend/purchase/purchase.db
